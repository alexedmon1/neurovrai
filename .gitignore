# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Test outputs and temporary files
*.nii.gz
*.bval
*.bvec
*.mat
*.log
b0_merged*
jac_*
warpfield_*
xfm_*

# Archived old code (reference only, no future changes tracked)
# archive/
logs/

# Regression contract — frozen fixtures/golden are committed even if they
# match the data-file patterns above (e.g. *.nii.gz, *.mat).
!tests/regression/fixtures/**
!tests/regression/golden/**
